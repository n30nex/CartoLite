# CartoLite runs a published image. Replace this with the digest in the release manifest.
CARTOLITE_IMAGE=ghcr.io/n30nex/cartolite@sha256:REPLACE_WITH_RELEASE_DIGEST
CARTOLITE_PUBLIC_BIND_ADDR=0.0.0.0
CARTOLITE_PUBLIC_PORT=80
CARTOLITE_BIND_ADDR=127.0.0.1
CARTOLITE_PORT=39476
# MeshCore MQTT. Copy this file to .env and keep the copy private.
MQTT_BROKER_URL=tcp://broker.example.invalid:1883
MQTT_TOPIC=meshcore/#
MQTT_CLIENT_ID=cartolite-production
MQTT_USERNAME=
MQTT_PASSWORD=
REGION_ALLOWLIST=YYZ,YKF,YOW,YVR

# Runtime state is a single atomic checkpoint, not an event database.
STATE_PATH=/data/state-v1.json
LOG_LEVEL=info
